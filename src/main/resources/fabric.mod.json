{
	"schemaVersion": 1,
	"id": "d_utils",
	"version": "${version}",
	"name": "D Utils",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"DEAMJAVA"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/d_utils/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "net.deamjava.d_utils.DUtils",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "net.deamjava.d_utils.DUtilsClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"d_utils.mixins.json",
		{
			"config": "d_utils.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}